<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/admin/admin.common.css" />
    <link rel="icon" href="https://res.cloudinary.com/dozcrwtud/image/upload/v1743746754/White_Minimalist_Online_Fashion_Shop_Bag_Logo_1_od2d4q.png">
    <link rel="stylesheet" href="/css/admin/admin.incomingnotification.css" />
    <link
      href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css"
      rel="stylesheet"
    />
    <title>Notifications - Admin panel</title>
    <style>
      .attribution {
        font-size: 11px;
        text-align: center;
      }

      .attribution a {
        color: hsl(228, 45%, 44%);
      }
    </style>
  </head>

  <body>
    <%- include("partials/sidebar.ejs") %>
    <div class="container">
      <div class="app">
        <div class="header">
          <h2>
            <span class="title">Notifications</span>
            <span class="unread-notification-number" id="unreadno"></span>
          </h2>
          <p onclick="markallasread()">Mark all as read</p>
        </div>
        <div class="body">
          <div class="notifications" id="notifications"></div>
          <div class="readednotification" id="readednotification"></div>
        </div>
      </div>

      <%- include("partials/footer.ejs") %>
    </div>

    <script src="/javascript/admin/admin.notifications.js"></script>
  </body>
</html>
