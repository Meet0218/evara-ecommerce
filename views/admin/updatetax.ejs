<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/admin/admin.updatetax.css" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    />
    <link
      rel="icon"
      href="https://res.cloudinary.com/dozcrwtud/image/upload/v1743746754/White_Minimalist_Online_Fashion_Shop_Bag_Logo_1_od2d4q.png"
    />
    <title>tax manage - Ecommerce Admin</title>
    <link
      href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css"
      rel="stylesheet"
    />
  </head>

  <body>
    <%- include("partials/sidebar.ejs") %>
    <div class="main-content">
      <div class="header">
        <h1>Tax Management</h1>
      </div>
      <div class="content">
        <form id="updatetaxform">
          <label for="catid">category id :</label>
          <input value="<%=result[0].parent_category_id%>" name="id" readonly>
          <label for="sgst">sgst</label>
          <input
            oninput="calculatetotaltax()"
            type="text"
            id="sgst"
            name="sgst"
            value="<%=result[0].s_gst%>"
          />
          <label for="cgst">cgst</label>
          <input
            oninput="calculatetotaltax()"
            type="text"
            id="cgst"
            name="cgst"
            value="<%=result[0].c_gst%>"
          />
          <label for="total">Total tax</label>
          <input readonly id="total" name="total" />
          <input type="submit" value="Update tax" />
        </form>
      </div>
      <%- include("partials/footer.ejs") %>
    </div>
  </body>
  <script src="/javascript/admin/admin.updatetax.js"></script>
</html>
