<%- include('partials/header') %>

<head>
  <link rel="icon" href="https://res.cloudinary.com/dozcrwtud/image/upload/v1743746754/White_Minimalist_Online_Fashion_Shop_Bag_Logo_1_od2d4q.png">
  <title>Signup</title>
  <link rel="stylesheet" href="/css/user/signup.css">
</head>

<div class="main-div">
  <div id="loader">

  </div>
  <div class="registration-div" id="registration">
    <form action="/auth/otp-verification" method="post" enctype="multipart/form-data" id="form">
      <div class="container">
        <h3>Create an Account</h3>
      </div>
      <div class="container">
        <input type="text" name="first_name" placeholder="First Name" />
      </div>
      <div class="container">
        <input type="text" name="last_name" placeholder="Last Name" />
      </div>
      <div class="container">
        <input type="text" name="contact" placeholder="Contact No" />
      </div>
      <div class="container">
        <input type="text" name="email" placeholder="Email" />
      </div>
      <div class="container-center">
        <input type="submit" value="Submit" id="submitBtn" />
        <input type="submit" value="Login" id="submitBtnLogin" />
      </div>
    </form>
  </div>
</div>
<script src="/javascript/user/user.signup.js">
  
</script>

<%- include('partials/footer') %>