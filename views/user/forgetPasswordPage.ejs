<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href="https://res.cloudinary.com/dozcrwtud/image/upload/v1743746754/White_Minimalist_Online_Fashion_Shop_Bag_Logo_1_od2d4q.png">
  <title>Forgot Password</title>
  <link rel="stylesheet" href="/css/user/forgotPassordPage.css">
</head>

<body>
  <div class="registration-div">
    <form enctype="multipart/form-data" id="form">
     
      <div id="email">
        <div class="container">
          <h3>Forget Password</h3>
        </div>
        <div class="container">
          <input type="text" name="email" placeholder="Email" />
        </div>
        <div class="container-center">
          <input type="submit" value="submit" id="createOtpBtn">
        </div>
      </div>
      <div id="otp">
        <div class="container">
          <h3>OTP Verification</h3>
        </div>
        <div class="container" >
          <input type="text" name="otp" placeholder="OTP" />
        </div>
        <div class="container-center">
          <input type="submit" value="submit" id="otpVerification">
        </div>
      </div>
      <div id="forget-password-div">
        <div class="container">
          <h3>Reset Password</h3>
        </div>
        <div class="container" >
            <input type="password" name="password" placeholder="Password" />
          </div>
          <div class="container" >
            <input type="password" name="confirmPassword" placeholder="Confirm Password" />
          </div>
          <div class="container-center">
            <input type="submit" value="submit" id="resetPasswordBtn">
          </div>
      </div>
    </form>
  </div>
  </div>
  <script src="/javascript/user/user.forgetPasswordPage.js">
    
  </script>
</body>

</html>
