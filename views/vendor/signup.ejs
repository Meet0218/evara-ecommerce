<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/vendor/vendor.signup.css" />
    <link rel="icon" href="https://res.cloudinary.com/dozcrwtud/image/upload/v1743746754/White_Minimalist_Online_Fashion_Shop_Bag_Logo_1_od2d4q.png">
    <title>Signup Page</title>
  </head>
  
  <body>
    <div class="loaderParent">
      <div class="loader"></div>
    </div>
    <div class="registration-div">
      <form
        action="/auth/vendor-otp-verification"
        method="post"
        enctype="multipart/form-data"
        id="form"
      >
        <div class="container">
          <h3>Create an Account For Vendor</h3>
        </div>
        <div class="container">
            <input type="text" name="first_name" placeholder="First Name" />
            <input type="text" name="last_name" placeholder="Last Name" />
        </div>
        <div class="container">
          <input type="text" name="contact" placeholder="Contact No" />
        </div>
        <div class="container">
          <input type="text" name="email" placeholder="Email" />
        </div>
        <div class="container">
          <input type="text" name="company_name" placeholder="Company Name" />
        </div>
        <div class="container">
          <input type="text" name="gst_number" placeholder="Gst Number" />
        </div>
        <div class="container">
          <input type="text" name="pincode" placeholder="Pincode" />
        </div>
        <div class="container">
          <div id="state"><%- stateSelectBox %></div>
          <div id="city">
            <select name="City" id="City" onchange="check(this)">
              <option value="">City</option>
            </select>
          </div>
        </div>

        <div class="container">
          <select name="category" id="">
            <option value="">Choose Category</option>
            <option value="1">Electronics</option>
            <option value="3">Clothes</option>
          </select>
        </div>

        <div class="container-center">
          <input type="submit" value="Submit" id="submitBtn" />
          <input type="submit" value="Login" id="submitBtnLogin" />
        </div>
      </form>
    </div>

  
     <script src="/javascript/vendor/vendor.signup.js"></script>
  </body>
</html>
