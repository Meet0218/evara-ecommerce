    .sidebar {
    width: 15%;
    background: hsl(176, 88%, 27%);/* Gradient sidebar */
    padding: 30px 20px;
    position: fixed;
    top: 0;
    left: 0;
    height: 100%;
    overflow-y: auto;
    box-shadow: 2px 0 10px rgba(0, 0, 0, 0.15);
    transition: width 0.3s ease;
    box-sizing: border-box;
    font-family: Verdana, Geneva, Tahoma, sans-serif;
  }
  
  .sidebar h2 {
    color: #fff;
    font-size: 26px;
    font-weight: 600;
    margin-bottom: 40px;
    text-align: center;
    letter-spacing: 1px;
  }
  
  .sidebar ul {
    list-style: none;
  }
  
  .sidebar ul li {
    margin: 15px 0;
  }
  
  .sidebar ul li a ,
  .logoutbtn{
    color: #dfe6e9;
    text-decoration: none;
    font-size: 16px;
    padding: 12px 20px;
    display: block;
    border-radius: 8px;
    transition: all 0.3s ease;
  }
  
  .sidebar ul li a:hover ,
  .logoutbtn:hover{
    background-color: rgba(255, 255, 255, 0.1);
    color: #fff;
    transform: translateX(5px);
  }
  #logo {
    height: 80px;
    width: 80px;
    border-radius: 25px ;
    object-fit: cover;
    margin-left: 45px;
  }

  .logoutbtn {
    background: none;
    border: none;
    font-size: 16px;
    cursor: pointer;
    transition: color 0.3s;
    color: white;
  }
  .actiePage a{
  background-color: rgba(255, 255, 255, 0.3);
  font-weight: bold;
}
  </style>
