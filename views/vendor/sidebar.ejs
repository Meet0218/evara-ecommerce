    <aside class="sidebar">
      
      <img id="logo" src="https://res.cloudinary.com/dozcrwtud/image/upload/v1743746754/White_Minimalist_Online_Fashion_Shop_Bag_Logo_1_od2d4q.png">
      <ul id="search">
        <li class="<%= currentPath == "/vendor/dashboard" ? "actiePage" : ""%>"><a href="/vendor/dashboard">Main Dashboard</a></li>
        <li class="<%= currentPath == "/vendor/getProducts" ? "actiePage" : ""%>"><a href="/vendor/getProducts">Products</a></li>
        <li class="<%= currentPath == "/vendor/getSalesPage" ? "actiePage" : ""%>"><a href="/vendor/getSalesPage">Sales</a></li>
        <li class="<%= currentPath == "/vendor/addProducts" ? "actiePage" : ""%>"><a href="/vendor/addProducts">Add Products</a></li>
        <li class="<%= currentPath == "/vendor/getReturnRequestPage" ? "actiePage" : ""%>"><a href="/vendor/getReturnRequestPage">Return Requests</a></li>
        <li class="<%= currentPath == "/vendor/orderRequests" ? "actiePage" : ""%>"><a href="/vendor/orderRequests">Order Requests</a></li>
        <li class="<%= currentPath == "/vendor/contact-to-admin" ? "actiePage" : ""%>"><a href="/vendor/contact-to-admin">Contact Admin</a></li>
        <li class="<%= currentPath == "/vendor/notifications" ? "actiePage" : ""%>"><a href="/vendor/notifications">Notifications</a></li>
        <li class="<%= currentPath == "/vendor/getProfile" ? "actiePage" : ""%>"><a href="/vendor/getProfile">Profile</a></li>
        <li><button class="logoutbtn" onclick="logout()">Logout</button></li>
        <p id="username" hidden><%=vendoremail %></p>
      </ul>
    </aside>

    <script>
      function logout() {
      // let response = confirm("Are you sure??");

      Swal.fire({
        text: "Are you sure you want to log out?",
        icon: "warning",
        showCancelButton: true,
        confirmButtonColor: "#3085d6",
        cancelButtonColor: "#d33",
        confirmButtonText: "Logout"
      }).then((result) => {
        if (result.isConfirmed) {
          window.location.href = '/vendor/logout';
        }
      });
    }

    </script>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/javascript/vendor/vendor.runtimenotification.js"></script>
