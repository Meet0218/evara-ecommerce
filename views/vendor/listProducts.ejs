  <body>
    <%- include("sidebar.ejs") %>
    <div class="main-div">
      <h1>Product Listing</h1>

      <div class="searchbar">
        <input
          type="text"
          placeholder="Search Product ...."
          name="search"
          id="searchInput"
          onkeyup="searchProduct()"
        />
      </div>
  
      <div class="container" id="listProducts"></div>
    </div>
   

    <div id="popup">
      <div class="popupdiv">
        <div class="topdiv">
          <i
            class="fa-solid fa-xmark"
            id="crossIcon"
            onclick="closePopUp()"
          ></i>
        </div>
        <div class="bottom">
          <div class="container-div">
            <input
              type="number"
              id="stockInput"
              class="stockInput"
              placeholder="Add Stocks"
            />
          </div>
          <div class="container-center">
            <input
              id="stockSubmitID"
              class="submitBtn"
              type="submit"
              value="submit"
              onclick="submitStock()"
            />
          </div>
        </div>
      </div>
    </div>
    <div id="updatePricePopup">
      <div class="popupdiv">
        <div class="topdiv">
          <i
            class="fa-solid fa-xmark"
            id="crossIcon"
            onclick="closePricePopUp()"
          ></i>
        </div>
        <div class="bottom">
          <div class="container-div">
            <input
              type="number"
              id="priceInput"
              class="priceInput"
              placeholder="Update Price"
            />
          </div>
          <div class="container-center">
            <input
              id="priceSubmitID"
              class="submitBtn"
              type="submit"
              value="submit"
              onclick="submitPrice()"
            />
          </div>
        </div>
      </div>
    </div>

    <div class="paginationButtons" id="paginationButtons">
      <button onclick="first_page_handler()"><<</button>
      <button onclick="prev_page_handler()"><</button>
      <button>
        Page <span id="current_page_id">1</span> of
        <span id="total_pages_id"></span>
      </button>
      <button onclick="next_page_handler()">></button>
      <button onclick="last_page_handler()">>></button>
    </div>
    <script src="/javascript/vendor/vendor.listProducts.js"></script>
  </body>
