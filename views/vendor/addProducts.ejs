<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/vendor/vendor.addProducts.css" />
    <link rel="icon" href="https://res.cloudinary.com/dozcrwtud/image/upload/v1743746754/White_Minimalist_Online_Fashion_Shop_Bag_Logo_1_od2d4q.png">
    <title>Vendor Add Products</title>
  </head>
  <body>
    <%- include("sidebar.ejs") %>
    <div class="loaderParent">
      <div class="loader"></div>
    </div>
    <main>
      <div class="main-div">
        <div class="registration-div">
          <div class="container-div ">
            <h3>Add Products</h3>
          </div>
          <form  id="productFormId">
            <div class="container">
              <div class="productImgDiv">
                <div class="productImgLeft">
                  <label for="productImgId" class="productImgLabel"
                    >Select Photos</label
                  ><br />
                    <input
                    type="file"
                    id="productImgId"
                    name="productImgs"
                    onchange="preview(this)"
                    multiple
                  />
                </div>
                <div class="productImgRight">
                  <div class="previewArea"></div>
                </div>
              </div>
             
            </div>
            <div class="container-div ">
              <input type="text" name="title" id="titleId" placeholder="Title"/>
            </div>
            <div class="container-div ">
              <textarea name="description" id="descriptionId" rows="4" cols="50" placeholder="Description"></textarea>
            </div>
            <div class="container-div ">
              <!-- <input type="text" name="color" id="colorId" placeholder="Color" /> -->
              <select name="color" id="colorId">
                <option value="">Select color</option>
              </select>
              <input type="number" name="stock" id="stockId" placeholder="Stock"/>
            </div>
            <div class="container-div">
              <input type="number" name="price" id="priceId" placeholder="Price"/>
            </div>
            <div class="category-container-div">
              
            <div class="categorySelectBox">
              <div class="Category" id="Category"></div>
              <div class="SubCategory1" id="SubCategory1"></div>
              <div class="SubCategory2" id="SubCategory2"></div>
              <div class="SubCategory3" id="SubCategory3"></div>
            </div>
            </div>
            <div class="container-div">

              <!-- <input type="text" name="size" id="sizeId" placeholder="Size"/> -->
              <select name="size" id="sizeId">
                <option value="">Select size</option>
              </select>
            </div>
            <div class="container-center">
          <input type="submit" value="submit" name="" id="" class="submitBtn" />
            </div>
          </form>
        </div>
      </div>
    </main>

    <script src="/javascript/vendor/vendor.addProducts.js"></script>

</html>
